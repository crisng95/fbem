# ── FBEM bridge (loopback only) ─────────────────────────────────────────────
FBEM_HTTP_PORT=47102
FBEM_WS_PORT=9224
FBEM_WS_HOST=127.0.0.1

# Base dir for FBEM state (captures + media). Default: ~/.fbem
# FBEM_HOME=~/.fbem

# Where captured templates live. They contain LIVE FB tokens — keep private.
# Reuse an existing captures dir (NO re-snapshot) by pointing here:
#   FBEM_CAPTURES_DIR=/path/to/existing/captures
# FBEM_CAPTURES_DIR=~/.fbem/captures

# Where the bridge serves media (mp4/jpg/png) to the extension over loopback.
# The MCP stages files here before posting. Default: ~/.fbem/media
# FBEM_MEDIA_DIR=~/.fbem/media

# ── FBEM MCP → bridge ───────────────────────────────────────────────────────
# Base URL the MCP server uses to reach the bridge.
# FBEM_BRIDGE_URL=http://127.0.0.1:47102

# ── Advanced tuning (rarely needed) ─────────────────────────────────────────
# How long a tab stays "fresh" before the extension auto-reloads it (seconds).
# FBEM_TAB_TTL_S=7200
# How recently a capture must arrive to count the tab as "active" (seconds).
# FBEM_TAB_ACTIVE_WINDOW_S=90
# Override the regex that identifies the Reel publish mutation (if FB renames it).
# FBEM_PUBLISH_OP_RE=
